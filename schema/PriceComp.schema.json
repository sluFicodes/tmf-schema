{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "priceComponentExtension",
    "title": "priceComponentExtension",
    "description": "An identifier for the usage specification and related party for product offering price",
    "type": "object",
    "properties": {
        "usageSpecId": {
            "type": "string",
            "description": "An identifier for the usage specification."
        },
        "relatedParty": {
            "type": "array",
            "description": "List of related parties",
            "items": {
                "$ref": "https://raw.githubusercontent.com/DOME-Marketplace/tmf-api/refs/heads/main/schemas/EngagedParty/RelatedParty.schema.json"
            }
        }
    },
    "additionalProperties": false
}
